# Copier ce fichier en .env.local et remplir les valeurs

# MongoDB — URI de connexion
MONGODB_URI=mongodb://localhost:27017/burkina-shop

# JWT — Secret fort (générer avec : openssl rand -base64 64)
JWT_SECRET=votre_secret_jwt_tres_long_et_securise

# Durée de validité du token JWT
JWT_EXPIRES_IN=7d

# URL du frontend Angular (pour CORS si nécessaire)
FRONTEND_URL=http://localhost:4200
